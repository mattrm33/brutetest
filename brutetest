<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login — SecureLab</title>
  <link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Rajdhani:wght@300;400;600&display=swap" rel="stylesheet">
  <style>
    :root {
      --green: #00ff88;
      --dark-green: #00cc66;
      --bg: #050a05;
      --panel: #0a140a;
      --border: #1a3a1a;
      --text: #c8e6c9;
      --dim: #4a7a4a;
      --red: #ff4444;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      background: var(--bg);
      font-family: 'Share Tech Mono', monospace;
      color: var(--text);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }

    /* Grid background */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image:
        linear-gradient(rgba(0,255,136,0.03) 1px, transparent 1px),
        linear-gradient(90deg, rgba(0,255,136,0.03) 1px, transparent 1px);
      background-size: 40px 40px;
      pointer-events: none;
    }

    /* Scanlines */
    body::after {
      content: '';
      position: fixed;
      inset: 0;
      background: repeating-linear-gradient(
        0deg,
        transparent,
        transparent 2px,
        rgba(0,0,0,0.15) 2px,
        rgba(0,0,0,0.15) 4px
      );
      pointer-events: none;
    }

    .container {
      width: 420px;
      position: relative;
      z-index: 10;
    }

    .header {
      text-align: center;
      margin-bottom: 32px;
    }

    .logo {
      font-family: 'Rajdhani', sans-serif;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 8px;
      color: var(--dim);
      text-transform: uppercase;
      margin-bottom: 8px;
    }

    .title {
      font-size: 13px;
      color: var(--green);
      letter-spacing: 3px;
      text-shadow: 0 0 20px rgba(0,255,136,0.5);
    }

    .blink {
      animation: blink 1s step-end infinite;
    }
    @keyframes blink {
      50% { opacity: 0; }
    }

    .panel {
      background: var(--panel);
      border: 1px solid var(--border);
      padding: 36px;
      position: relative;
      box-shadow:
        0 0 40px rgba(0,255,136,0.05),
        inset 0 1px 0 rgba(0,255,136,0.1);
    }

    .panel::before {
      content: '[ AUTH_MODULE v2.1 ]';
      position: absolute;
      top: -10px;
      left: 20px;
      background: var(--panel);
      padding: 0 8px;
      font-size: 10px;
      color: var(--dim);
      letter-spacing: 2px;
    }

    .corner {
      position: absolute;
      width: 10px;
      height: 10px;
      border-color: var(--green);
      border-style: solid;
    }
    .corner.tl { top: -1px; left: -1px; border-width: 2px 0 0 2px; }
    .corner.tr { top: -1px; right: -1px; border-width: 2px 2px 0 0; }
    .corner.bl { bottom: -1px; left: -1px; border-width: 0 0 2px 2px; }
    .corner.br { bottom: -1px; right: -1px; border-width: 0 2px 2px 0; }

    .field {
      margin-bottom: 20px;
    }

    label {
      display: block;
      font-size: 10px;
      letter-spacing: 3px;
      color: var(--dim);
      margin-bottom: 8px;
      text-transform: uppercase;
    }

    input {
      width: 100%;
      background: rgba(0,255,136,0.03);
      border: 1px solid var(--border);
      border-top-color: rgba(0,255,136,0.1);
      color: var(--green);
      font-family: 'Share Tech Mono', monospace;
      font-size: 14px;
      padding: 12px 14px;
      outline: none;
      transition: border-color 0.2s, box-shadow 0.2s;
      letter-spacing: 1px;
    }

    input:focus {
      border-color: rgba(0,255,136,0.4);
      box-shadow: 0 0 15px rgba(0,255,136,0.1);
      background: rgba(0,255,136,0.05);
    }

    input::placeholder { color: var(--dim); opacity: 0.5; }

    .btn {
      width: 100%;
      margin-top: 8px;
      padding: 14px;
      background: transparent;
      border: 1px solid var(--green);
      color: var(--green);
      font-family: 'Share Tech Mono', monospace;
      font-size: 12px;
      letter-spacing: 4px;
      text-transform: uppercase;
      cursor: pointer;
      transition: all 0.2s;
      position: relative;
      overflow: hidden;
    }

    .btn::before {
      content: '';
      position: absolute;
      inset: 0;
      background: var(--green);
      transform: translateX(-100%);
      transition: transform 0.3s ease;
      opacity: 0.1;
    }

    .btn:hover::before { transform: translateX(0); }
    .btn:hover {
      box-shadow: 0 0 25px rgba(0,255,136,0.3);
      text-shadow: 0 0 10px var(--green);
    }
    .btn:active { transform: scale(0.99); }

    .status {
      margin-top: 20px;
      padding: 12px;
      font-size: 11px;
      letter-spacing: 2px;
      text-align: center;
      min-height: 42px;
      border: 1px solid transparent;
      transition: all 0.3s;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
    }

    .status.error {
      border-color: rgba(255,68,68,0.3);
      background: rgba(255,68,68,0.05);
      color: var(--red);
    }

    .status.success {
      border-color: rgba(0,255,136,0.3);
      background: rgba(0,255,136,0.05);
      color: var(--green);
      animation: pulse 0.5s ease;
    }

    @keyframes pulse {
      0% { transform: scale(1); }
      50% { transform: scale(1.01); }
      100% { transform: scale(1); }
    }

    .footer {
      text-align: center;
      margin-top: 24px;
      font-size: 10px;
      color: var(--dim);
      letter-spacing: 2px;
      opacity: 0.5;
    }

    .attempt-counter {
      position: absolute;
      top: 12px;
      right: 20px;
      font-size: 9px;
      color: var(--dim);
      letter-spacing: 1px;
    }

    /* Matrix rain effect */
    canvas {
      position: fixed;
      top: 0;
      left: 0;
      z-index: 1;
      opacity: 0.04;
      pointer-events: none;
    }
  </style>
</head>
<body>

<canvas id="matrix"></canvas>

<div class="container">
  <div class="header">
    <div class="logo">// SecureLab Training Environment</div>
    <div class="title">SYSTÈME D'AUTHENTIFICATION <span class="blink">_</span></div>
  </div>

  <div class="panel">
    <div class="corner tl"></div>
    <div class="corner tr"></div>
    <div class="corner bl"></div>
    <div class="corner br"></div>
    <div class="attempt-counter" id="counter">ATTEMPTS: 0</div>

    <div class="field">
      <label>// Identifiant</label>
      <input type="text" id="username" placeholder="username" autocomplete="off" />
    </div>

    <div class="field">
      <label>// Mot de passe</label>
      <input type="password" id="password" placeholder="password" autocomplete="off" />
    </div>

    <button class="btn" onclick="tryLogin()">[ CONNEXION ]</button>

    <div class="status" id="status"></div>
  </div>

  <div class="footer">// TRAINING ENV — BRUTE FORCE PRACTICE LAB</div>
</div>

<script>
  // ─── Credentials ───────────────────────────────────────────────
  const VALID_USER = "admin";
  const VALID_PASS = "1234";   // mot de passe volontairement trivial
  // ───────────────────────────────────────────────────────────────

  let attempts = 0;

  function tryLogin() {
    const u = document.getElementById('username').value;
    const p = document.getElementById('password').value;
    const status = document.getElementById('status');
    const counter = document.getElementById('counter');

    attempts++;
    counter.textContent = `ATTEMPTS: ${attempts}`;

    status.className = 'status';
    status.textContent = '';

    if (u === VALID_USER && p === VALID_PASS) {
      status.className = 'status success';
      status.innerHTML = '✓ &nbsp; ACCÈS AUTORISÉ — BIENVENUE ' + u.toUpperCase();
    } else if (u !== VALID_USER) {
      status.className = 'status error';
      status.innerHTML = '✗ &nbsp; UTILISATEUR INCONNU';
    } else {
      status.className = 'status error';
      status.innerHTML = `✗ &nbsp; MOT DE PASSE INCORRECT [TENTATIVE #${attempts}]`;
    }
  }

  // Enter key support
  document.addEventListener('keydown', e => {
    if (e.key === 'Enter') tryLogin();
  });

  // Matrix rain
  const canvas = document.getElementById('matrix');
  const ctx = canvas.getContext('2d');
  canvas.width = window.innerWidth;
  canvas.height = window.innerHeight;

  const cols = Math.floor(canvas.width / 14);
  const drops = Array(cols).fill(1);
  const chars = '01アイウエオカキクケコサシスセソタチツテトナニヌネノ';

  function drawMatrix() {
    ctx.fillStyle = 'rgba(5,10,5,0.05)';
    ctx.fillRect(0, 0, canvas.width, canvas.height);
    ctx.fillStyle = '#00ff88';
    ctx.font = '12px Share Tech Mono';
    drops.forEach((y, i) => {
      const char = chars[Math.floor(Math.random() * chars.length)];
      ctx.fillText(char, i * 14, y * 14);
      if (y * 14 > canvas.height && Math.random() > 0.975) drops[i] = 0;
      drops[i]++;
    });
  }

  setInterval(drawMatrix, 50);
</script>
</body>
</html>
